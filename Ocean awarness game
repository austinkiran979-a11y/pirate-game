<!DOCTYPE html>
<html>
<head>
<title>Coin Quest</title>
<style>
body{
margin:0;
background:#222;
overflow:hidden;
font-family:Arial;
}
canvas{
display:block;
margin:auto;
background:#87CEEB;
}
#ui{
position:absolute;
top:10px;
left:10px;
background:white;
padding:10px;
border-radius:10px;
}
button{
padding:10px;
font-size:18px;
}
</style>
</head>
<body>

<div id="ui">
<div id="stats"></div>
<button onclick="location.reload()">Restart</button>
</div>

<canvas id="game" width="1000" height="600"></canvas>

<script>
const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");

let keys={};

document.addEventListener("keydown",e=>{
keys[e.key.toLowerCase()]=true;
});

document.addEventListener("keyup",e=>{
keys[e.key.toLowerCase()]=false;
});

const player={
x:50,
y:300,
size:25,
speed:4,
health:100,
coins:0
};

let level=1;

let coins=[];
let enemies=[];

function loadLevel(){

coins=[];
enemies=[];

if(level===1){

for(let i=0;i<5;i++){
coins.push({
x:150+i*140,
y:100+Math.random()*350
});
}

enemies.push({
x:500,
y:200,
dir:1
});
}

if(level===2){

for(let i=0;i<8;i++){
coins.push({
x:100+Math.random()*800,
y:80+Math.random()*450
});
}

enemies.push(
{x:400,y:200,dir:1},
{x:700,y:350,dir:-1}
);
}

if(level===3){

for(let i=0;i<12;i++){
coins.push({
x:100+Math.random()*800,
y:80+Math.random()*450
});
}

enemies.push(
{x:300,y:150,dir:1},
{x:600,y:300,dir:-1},
{x:800,y:200,dir:1}
);
}
}

loadLevel();

function update(){

if(keys["w"]) player.y-=player.speed;
if(keys["s"]) player.y+=player.speed;
if(keys["a"]) player.x-=player.speed;
if(keys["d"]) player.x+=player.speed;

player.x=Math.max(0,Math.min(canvas.width-player.size,player.x));
player.y=Math.max(0,Math.min(canvas.height-player.size,player.y));

for(let i=coins.length-1;i>=0;i--){

let c=coins[i];

if(Math.hypot(player.x-c.x,player.y-c.y)<25){

coins.splice(i,1);
player.coins++;
}
}

for(let e of enemies){

e.y+=e.dir*2;

if(e.y<50 || e.y>550){
e.dir*=-1;
}

if(Math.hypot(player.x-e.x,player.y-e.y)<30){
player.health-=0.2;
}
}

if(player.health<=0){

alert("Game Over");
location.reload();
}

if(coins.length===0){

level++;

if(level>3){
win=true;
}else{
player.x=50;
player.y=300;
loadLevel();
}
}
}

let win=false;

function draw(){

ctx.clearRect(0,0,canvas.width,canvas.height);

if(level===1) ctx.fillStyle="#8fd14f";
if(level===2) ctx.fillStyle="#d2b48c";
if(level===3) ctx.fillStyle="#7c5cff";

ctx.fillRect(0,0,canvas.width,canvas.height);

for(let c of coins){

ctx.fillStyle="gold";
ctx.beginPath();
ctx.arc(c.x,c.y,10,0,Math.PI*2);
ctx.fill();
}

for(let e of enemies){

ctx.fillStyle="red";
ctx.fillRect(e.x-15,e.y-15,30,30);
}

ctx.fillStyle="blue";
ctx.fillRect(
player.x,
player.y,
player.size,
player.size
);

if(win){

ctx.fillStyle="black";
ctx.font="60px Arial";
ctx.fillText(
"YOU WIN!",
350,
300
);
}
}

function ui(){

document.getElementById("stats").innerHTML=
"Level: "+Math.min(level,3)+
"<br>Health: "+Math.floor(player.health)+
"<br>Coins: "+player.coins;
}

function gameLoop(){

if(!win){
update();
}

draw();
ui();

requestAnimationFrame(gameLoop);
}

gameLoop();
</script>

</body>
</html>
